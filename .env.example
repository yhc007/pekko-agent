# pekko-agent Environment Configuration

# Claude API
CLAUDE_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096

# Database — embedded coreDB (no external DB required)
COREDB_DATA_DIR=./data/coredb

# Event Streaming — pekko-event-bus (embedded, no external Kafka required)
# No configuration needed - runs in-process

# Qdrant Vector Database (local binary or remote server)
# Local:  brew install qdrant && qdrant --storage-path ./data/qdrant
# Remote: point to your Qdrant server
# Docker: docker run -p 6333:6333 qdrant/qdrant
QDRANT_URL=http://localhost:6333

# Service Ports
API_GATEWAY_PORT=8080
ORCHESTRATOR_PORT=50051
LLM_GATEWAY_PORT=50052
TOOL_REGISTRY_PORT=50053
MEMORY_SERVICE_PORT=50054
PERMIT_AGENT_PORT=50055
INSPECTION_AGENT_PORT=50056
COMPLIANCE_AGENT_PORT=50057
AUDIT_PORT=50058

# Security
JWT_SECRET=your-jwt-secret-here
TOKEN_BUDGET_DAILY=1000000
RATE_LIMIT_RPM=1000

# Logging
RUST_LOG=info
