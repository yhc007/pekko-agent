# pekko-agent Environment Configuration
# 복사 후 실제 값으로 변경: cp .env.example .env

# ── LLM ──────────────────────────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096
LLM_PROVIDER=claude

# Optional: multi-provider fallback
# GOOGLE_API_KEY=your-gemini-key
# GEMINI_MODEL=gemini-2.0-flash
# OPENAI_API_KEY=your-openai-key
# OPENAI_MODEL=gpt-4o

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://pekko:pekko_secret@localhost:5432/pekko_agent
POSTGRES_PASSWORD=pekko_secret

# ── Security ──────────────────────────────────────────────────────────────────
# JWT_SECRET must be at least 32 characters in production
JWT_SECRET=change-me-in-production-32-chars!!
JWT_TTL_SECONDS=3600
ADMIN_API_KEY=your-admin-api-key-here
AGENT_API_KEY=your-agent-api-key-here

# ── Rate Limiting (requests per minute) ──────────────────────────────────────
RATE_LIMIT_ADMIN_RPM=1000
RATE_LIMIT_AGENT_RPM=300
RATE_LIMIT_DEFAULT_RPM=60

# ── Circuit Breaker ───────────────────────────────────────────────────────────
CB_MAX_FAILURES=5
CB_CALL_TIMEOUT_SECS=30
CB_RESET_TIMEOUT_SECS=60

# ── Vector Store (pgvector) ───────────────────────────────────────────────────
# Set to true if pgvector extension is not installed in PostgreSQL
# DISABLE_VECTOR_STORE=true
# Embeddings use OPENAI_API_KEY above; set EMBEDDING_MODEL to override
# EMBEDDING_MODEL=text-embedding-3-small

# ── Orchestrator Persistence ──────────────────────────────────────────────────
# Set to true for ephemeral/test environments (skips DB persistence)
# DISABLE_ORCHESTRATOR_PERSISTENCE=true

# ── Service Ports ─────────────────────────────────────────────────────────────
API_GATEWAY_PORT=8080

# ── Observability ─────────────────────────────────────────────────────────────
RUST_LOG=info
# Enable OpenTelemetry export (Jaeger / OTLP-compatible collector)
# OTLP_ENDPOINT=http://localhost:4317
